# Server
PORT=5000
NODE_ENV=development

# CORS - comma-separated allowed origins
ALLOWED_ORIGINS=http://localhost:3000

# PostgreSQL
DB_HOST=localhost
DB_PORT=5432
DB_NAME=rfp_management
DB_USER=postgres
DB_PASSWORD=your_password_here
# Set to "false" to disable SSL cert validation in production (not recommended)
# DB_SSL_REJECT_UNAUTHORIZED=true

# Authentication — generate with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=your-jwt-secret-here-generate-with-crypto
JWT_REFRESH_SECRET=your-jwt-refresh-secret-here-generate-with-crypto

# OpenAI
OPENAI_API_KEY=sk-your-openai-api-key-here

# AI Configuration (optional — defaults shown)
# AI_MODEL=gpt-4o-mini
# AI_TIMEOUT_MS=60000
# AI_MAX_INPUT_LENGTH=100000
# EMBEDDING_MODEL=text-embedding-3-small

# Logging (optional — defaults to "info" in production, "debug" in development)
# LOG_LEVEL=info

# SMTP (Outgoing Email)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASSWORD=your-app-password-here
SMTP_FROM=your-email@gmail.com

# IMAP (Incoming Email)
IMAP_HOST=imap.gmail.com
IMAP_PORT=993
IMAP_USER=your-email@gmail.com
IMAP_PASSWORD=your-app-password-here
